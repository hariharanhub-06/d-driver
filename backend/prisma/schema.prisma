generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  address           String?
  logo_url          String?
  primary_color     String?  @default("#2dbc75")
  phone             String?
  email_contact     String?
  subscription_plan String   @default("Basic")
  status            String   @default("Active")
  permissions       Json?    // Stores feature-level access (e.g., { "attendance_popups": true, "live_tracking": true })
  created_at        DateTime @default(now())

  users         User[]
  buses         Bus[]
  drivers       Driver[]
  routes        Route[]
  students      Student[]
  attendance    Attendance[]
  fees          Fee[]
  payments      Payment[]
  locations     Location[]
  notifications Notification[]
  stops         Stop[]
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  phone      String?  @unique
  role       String   // "super_admin", "admin", "driver", "parent"
  school_id  String?
  created_at DateTime @default(now())

  school   School?   @relation(fields: [school_id], references: [id])
  driver   Driver?
  children Student[] @relation("ParentStudents")
}

model Bus {
  id         String @id @default(uuid())
  bus_number String
  capacity   Int
  school_id  String

  school    School     @relation(fields: [school_id], references: [id])
  drivers   Driver[]
  locations Location[]
}

model Driver {
  id              String  @id @default(uuid())
  user_id         String  @unique
  license_no      String?
  assigned_bus_id String?
  school_id       String

  user   User   @relation(fields: [user_id], references: [id])
  bus    Bus?   @relation(fields: [assigned_bus_id], references: [id])
  school School @relation(fields: [school_id], references: [id])
}

model Route {
  id          String   @id @default(uuid())
  name        String
  start_point String?  // e.g., "School Main Gate"
  end_point   String?  // e.g., "Sector 12 Circular"
  school_id   String

  school   School    @relation(fields: [school_id], references: [id])
  stops    Stop[]
  students Student[]
}

model Stop {
  id        String @id @default(uuid())
  name      String
  latitude  Float
  longitude Float
  route_id  String
  school_id String

  school   School    @relation(fields: [school_id], references: [id])
  route    Route     @relation(fields: [route_id], references: [id])
  students Student[]
}

model Student {
  id        String  @id @default(uuid())
  name      String
  grade     String?
  section   String?
  gr_no     String?
  parent_id String?
  route_id  String?
  stop_id   String?
  school_id String

  school     School       @relation(fields: [school_id], references: [id])
  route      Route?       @relation(fields: [route_id], references: [id])
  stop       Stop?        @relation(fields: [stop_id], references: [id])
  parent     User?        @relation("ParentStudents", fields: [parent_id], references: [id])
  attendance Attendance[]
  fees       Fee[]
}

model Attendance {
  id         String   @id @default(uuid())
  student_id String
  date       DateTime @default(now())
  status     String   // "present", "absent", "missed"
  school_id  String

  student Student @relation(fields: [student_id], references: [id])
  school  School  @relation(fields: [school_id], references: [id])
}

model Fee {
  id           String   @id @default(uuid())
  student_id   String
  total_amount Float
  due_amount   Float
  due_date     DateTime
  school_id    String

  student  Student   @relation(fields: [student_id], references: [id])
  school   School    @relation(fields: [school_id], references: [id])
  payments Payment[]
}

model Payment {
  id           String   @id @default(uuid())
  fee_id       String
  amount       Float
  status       String   // "paid", "pending", "overdue"
  payment_date DateTime @default(now())
  school_id    String

  fee    Fee    @relation(fields: [fee_id], references: [id])
  school School @relation(fields: [school_id], references: [id])
}

model Location {
  id        String   @id @default(uuid())
  bus_id    String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
  school_id String

  bus    Bus    @relation(fields: [bus_id], references: [id])
  school School @relation(fields: [school_id], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  message    String
  type       String
  created_at DateTime @default(now())
  school_id  String

  school School @relation(fields: [school_id], references: [id])
}
