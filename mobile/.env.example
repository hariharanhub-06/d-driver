# Copy to .env and set for local dev. EXPO_PUBLIC_* vars are inlined at build time.
# Point at your running backend (web app defaults to localhost:2024).
EXPO_PUBLIC_API_URL=http://localhost:2024/api/v1
# Optional: where non-parent roles are sent ("Open web app").
EXPO_PUBLIC_WEB_URL=https://app.d-driver.com
